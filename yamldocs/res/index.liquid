{% endcomment %}
{% from "macros" import meta %}
<!DOCTYPE html>
<html lang="en_us" >
    {{ meta() }}

    {% if github_slug != blank %}
        <title>Yaml Docs {{ github_slug }}</title>
    {%  else %}
        <title>Robust Yaml Documentation </title>
    {% endif %}
<body>
{% if github_slug != blank %}
    <h1>Yaml documentation for <a href="https://github.com/{{ github_slug }}">{{ github_slug }}</a></h1>
{%  else %}
    <h1>Robust Yaml documentation</h1>
{% endif %}

<p>
    Documentation generated by <a href="https://github.com/dffdff2423/librobustyaml">Yamldocs</a>
</p>

<h3>Jump to</h3>
<ul>
    <li><a href="#prototypes">Prototypes</a></li>
    <li><a href="#components">Components</a></li>
    <li><a href="#data-defs">Data Definitions</a></li>
</ul>

<p>
    <!--suppress HtmlUnknownTarget -->
    For information about builtin types see <a href="./base-types.html"> here</a>
</p>

<p>
    <!--suppress HtmlUnknownTarget -->
    A <a href="./types.json">JSON version</a> of this documentation is also available.
</p>

<h2 id="prototypes">Prototypes</h2>
{% for proto in asm_types.Prototypes %}
    <div class="boxed">
        <h3><a href="./{{ proto }}.html">{{ proto }}</a></h3>
        {{ type_info.Prototypes[proto].Docs | format_docs }}
    </div>
{% endfor %}
<h2 id="components">Components</h2>
{% for comp in asm_types.Components %}
    <div class="boxed">
        <h3><a href="./{{ comp }}.html">{{ comp }}</a></h3>
        {{ type_info.Components[comp].Docs | format_docs }}
    </div>
{% endfor %}
<h2 id="data-defs">Data Definitions</h2>
{% for dd in asm_types.DataDefs %}
    <div class="boxed">
        <h3><a href="./{{ dd | url_encode }}.html">{{ dd }}</a></h3>
        {{ type_info.DataDefinitions[dd].Docs | format_docs }}
    </div>
{% endfor %}
</body>
</html>
